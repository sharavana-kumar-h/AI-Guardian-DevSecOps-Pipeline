# Optional build-time metadata used by Day 17 container hardening.
# The Dockerfile accepts these as --build-arg values.
APP_VERSION=0.1.0
VCS_REF=$(git rev-parse --short HEAD 2>/dev/null || echo local)
BUILD_DATE=$(date -u +%Y-%m-%dT%H:%M:%SZ)
IMAGE_SOURCE=https://github.com/YOUR_USERNAME/ai-guardian-devsecops-pipeline
